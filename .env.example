# ============================================
# Public site URL (production domain — required on Vercel)
# ============================================
# Must be https://kdcuganda.org (not *.vercel.app) for sitemap & Search Console.
NEXT_PUBLIC_SITE_URL=https://kdcuganda.org

# ============================================
# Supabase Configuration
# ============================================

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://wuqhrjczlolhiaihosei.supabase.co

# Supabase anonymous key (public, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (server-side only, keep secret)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# Sermon AI Link Processor Configuration
# ============================================

# Google Gemini API Key (free tier)
# Get your key at: https://ai.google.dev/
GEMINI_API_KEY=

# Processing timeout in milliseconds (default: 10 minutes)
AI_PROCESSING_TIMEOUT_MS=600000

# Rate limit: max processing requests per user per hour (default: 5)
AI_RATE_LIMIT_PER_HOUR=5

# ─────────────────────────────────────────────────────────────────────────────
# Queue Processor (Sermon Queue Processor)
# ─────────────────────────────────────────────────────────────────────────────

# Redis connection URL (required for queue processor)
# Install Redis: https://redis.io/docs/getting-started/
REDIS_URL=redis://localhost:6379

# Ollama API endpoint (self-hosted AI)
# Install Ollama: https://ollama.ai/
OLLAMA_ENDPOINT=http://localhost:11434

# Ollama model to use for summarization and SEO generation
OLLAMA_MODEL=mistral

# Whisper model size (base, small, medium, large)
# Install faster-whisper: pip install faster-whisper
WHISPER_MODEL=base

# Number of concurrent jobs per worker process (default: 1)
WORKER_CONCURRENCY=1

# Job timeout in milliseconds (default: 60 minutes)
JOB_TIMEOUT_MS=3600000

# Rate limit: max job submissions per user per hour (default: 10)
RATE_LIMIT_PER_HOUR=10

# Temporary directory for audio files (default: /tmp/sermon-audio)
TEMP_AUDIO_DIR=/tmp/sermon-audio

# Enable queue processor feature flag (default: false)
# Set to true to use queue processor instead of synchronous processor
ENABLE_QUEUE_PROCESSOR=false

# ============================================
# Exchange Rate API (Geo-Currency Feature)
# ============================================

# API key for exchangerate-api.com (free tier: 1,500 req/month)
# Get your key at: https://www.exchangerate-api.com/
# Rates are cached in Supabase for 24 hours (~30 req/month used)
EXCHANGE_RATE_API_KEY=your_exchange_rate_api_key_here

# ============================================
# Google OAuth (Analytics, Search Console, Indexing, YouTube)
# ============================================
# Redirect URI: {SITE_URL}/api/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ============================================
# Meta / Facebook / Instagram (Digital Ministry Phase 2)
# ============================================
# Redirect URI: {SITE_URL}/api/meta/callback
META_APP_ID=
META_APP_SECRET=

# Optional: dedicated AES key for dm_social_accounts tokens (else service role key is hashed)
# DM_TOKEN_ENCRYPTION_KEY=

# Cron secret for Growth Coach daily job
# GET/POST /api/digital-ministry/cron/growth with Authorization: Bearer <secret>
# CRON_SECRET=
# DM_CRON_SECRET=

# ============================================
# Live Stream / YouTube
# ============================================

# YouTube channel URL used for social links and live stream fallback
NEXT_PUBLIC_SOCIAL_YOUTUBE=https://www.youtube.com/@bishopclimateministries

# Optional: YouTube channel ID (UC...) for the Watch Live embed
NEXT_PUBLIC_YOUTUBE_CHANNEL_ID=UChhdehWEPhFS7ebO8WDEjEA

# Optional: override the full iframe embed URL used on /live
# NEXT_PUBLIC_LIVE_STREAM_URL=https://www.youtube.com/embed/live_stream?channel=UC...
