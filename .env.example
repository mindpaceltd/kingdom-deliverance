# ============================================
# Supabase Configuration
# ============================================

# Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://wuqhrjczlolhiaihosei.supabase.co

# Supabase anonymous key (public, safe to expose)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here

# Supabase service role key (server-side only, keep secret)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ============================================
# Sermon AI Link Processor Configuration
# ============================================

# Google Gemini API Key (free tier)
# Get your key at: https://ai.google.dev/
GEMINI_API_KEY=

# Processing timeout in milliseconds (default: 10 minutes)
AI_PROCESSING_TIMEOUT_MS=600000

# Rate limit: max processing requests per user per hour (default: 5)
AI_RATE_LIMIT_PER_HOUR=5

# ─────────────────────────────────────────────────────────────────────────────
# Queue Processor (Sermon Queue Processor)
# ─────────────────────────────────────────────────────────────────────────────

# Redis connection URL (required for queue processor)
# Install Redis: https://redis.io/docs/getting-started/
REDIS_URL=redis://localhost:6379

# Ollama API endpoint (self-hosted AI)
# Install Ollama: https://ollama.ai/
OLLAMA_ENDPOINT=http://localhost:11434

# Ollama model to use for summarization and SEO generation
OLLAMA_MODEL=mistral

# Whisper model size (base, small, medium, large)
# Install faster-whisper: pip install faster-whisper
WHISPER_MODEL=base

# Number of concurrent jobs per worker process (default: 1)
WORKER_CONCURRENCY=1

# Job timeout in milliseconds (default: 60 minutes)
JOB_TIMEOUT_MS=3600000

# Rate limit: max job submissions per user per hour (default: 10)
RATE_LIMIT_PER_HOUR=10

# Temporary directory for audio files (default: /tmp/sermon-audio)
TEMP_AUDIO_DIR=/tmp/sermon-audio

# Enable queue processor feature flag (default: false)
# Set to true to use queue processor instead of synchronous processor
ENABLE_QUEUE_PROCESSOR=false
